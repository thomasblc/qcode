    "llama:start": "./scripts/start-llama-server.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@qvac/sdk": "^0.8.3",
    "diff": "^7.0.0",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
